# EduAI Platform - Backend API Environment Configuration

# ========================================
# SERVICE CONFIGURATION
# ========================================
NODE_ENV=production
PORT=5000
API_VERSION=v1

# ========================================
# SECURITY
# ========================================
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_long
JWT_REFRESH_SECRET=your_super_secret_refresh_key_minimum_32_characters_long
JWT_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12

# ========================================
# DATABASE CONFIGURATION
# ========================================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=eduai_db
DB_USER=postgres
DB_PASSWORD=your_secure_database_password
DB_SSL_MODE=prefer
DB_POOL_MIN=2
DB_POOL_MAX=20

# ========================================
# REDIS CONFIGURATION
# ========================================
REDIS_URL=redis://:your_redis_password@redis:6379
REDIS_TTL=3600
REDIS_SESSION_TTL=86400

# ========================================
# AI SERVICE
# ========================================
AI_SERVICE_URL=http://ai-service:8000
AI_SERVICE_TIMEOUT=30000

# ========================================
# OBJECT STORAGE (S3/MinIO)
# ========================================
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1
S3_ENDPOINT=http://minio:9000
S3_BUCKET=eduai-uploads
S3_USE_SSL=false
S3_FORCE_PATH_STYLE=true

# ========================================
# EMAIL CONFIGURATION
# ========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@eduai.com
EMAIL_FROM_NAME=EduAI Platform

# ========================================
# CORS & SECURITY
# ========================================
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ========================================
# LOGGING
# ========================================
LOG_LEVEL=info
LOG_FILE_PATH=/app/logs/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5

# ========================================
# MONITORING
# ========================================
PROMETHEUS_ENABLED=true
METRICS_PATH=/metrics
