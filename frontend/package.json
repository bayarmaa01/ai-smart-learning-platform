{
  "name": "ai-learning-platform-frontend",
  "version": "1.0.0+2026-04-13T15-16-02+2026-04-13T15-16-34+2026-04-13T15-21-26+2026-04-13T15-21-45+2026-04-14T13-13-48+2026-04-14T13-53-10+2026-04-15T07-30-00+2026-04-16T14-30-00+2026-04-16T14-30-34+2026-04-16T14-30-48+2026-04-16T14-31-16+2026-04-16T14-49-08",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "npm run version:patch && vite build",
    "build:prod": "npm run version:patch && NODE_ENV=production vite build",
    "preview": "vite preview",
    "version:patch": "node -e \"const pkg=require('./package.json'); const timestamp=new Date().toISOString().replace(/[:.]/g,'-').slice(0,19); pkg.version=pkg.version.replace(/\\+\\d+$/,'')+'+'+timestamp; require('fs').writeFileSync('./package.json', JSON.stringify(pkg, null, 2));\"",
    "version:minor": "npm version minor && npm run version:patch",
    "version:major": "npm version major && npm run version:patch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --coverage --reporter=junit --reporter=default --outputFile=test-results.xml",
    "test:watch": "vitest",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "lint:check": "eslint src --max-warnings=0"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.2.1",
    "@tanstack/react-query": "^5.99.0",
    "axios": "^1.6.7",
    "clsx": "^2.1.0",
    "date-fns": "^3.3.1",
    "i18next": "^23.10.0",
    "i18next-browser-languagedetector": "^7.2.1",
    "i18next-http-backend": "^2.5.0",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^0.344.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "react-i18next": "^14.1.0",
    "react-markdown": "^9.0.1",
    "react-redux": "^9.1.0",
    "react-router-dom": "^6.22.2",
    "recharts": "^2.12.2",
    "socket.io-client": "^4.7.4",
    "uuid": "^9.0.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^15.0.2",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.6.1",
    "autoprefixer": "^10.4.18",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^8.0.3",
    "jsdom": "^24.0.0",
    "lint-staged": "^15.2.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.4",
    "vitest": "^1.6.1"
  },
  "overrides": {
    "rollup": "^4.0.0"
  }
}