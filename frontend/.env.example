# EduAI Platform - Frontend Environment Configuration

# ========================================
# API ENDPOINTS
# ========================================
VITE_API_URL=http://localhost:5000/api/v1
VITE_AI_URL=http://localhost:8001
VITE_SOCKET_URL=http://localhost:5000

# ========================================
# APPLICATION CONFIGURATION
# ========================================
VITE_APP_NAME=EduAI Platform
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=AI-Powered Multilingual Learning Platform

# ========================================
# FEATURES
# ========================================
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_CHAT=true
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_DARK_MODE=true

# ========================================
# LANGUAGE CONFIGURATION
# ========================================
VITE_DEFAULT_LANGUAGE=en
VITE_SUPPORTED_LANGUAGES=en,mn

# ========================================
# AUTHENTICATION
# ========================================
VITE_AUTH_TOKEN_KEY=eduai_token
VITE_AUTH_REFRESH_KEY=eduai_refresh_token
VITE_AUTH_USER_KEY=eduai_user

# ========================================
# PRODUCTION CONFIGURATION
# ========================================
VITE_API_BASE_URL=https://api.yourdomain.com
VITE_AI_BASE_URL=https://ai.yourdomain.com
VITE_SOCKET_BASE_URL=https://api.yourdomain.com
