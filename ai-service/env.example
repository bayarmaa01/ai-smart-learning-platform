# EduAI Platform - AI Service Environment Configuration

# ========================================
# SERVICE CONFIGURATION
# ========================================
DEBUG=false
HOST=0.0.0.0
PORT=8000
WORKERS=4

# ========================================
# SECURITY
# ========================================
API_KEY=your_api_key_here
# Option 1: JSON array format (recommended)
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:5000", "https://yourdomain.com"]

# Option 2: Comma-separated format (also works)
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000,https://yourdomain.com
ALLOWED_HOSTS=["*"]

# ========================================
# DATABASE
# ========================================
DATABASE_URL=postgresql://postgres:your_secure_password@postgres:5432/eduai_db

# ========================================
# REDIS CACHE
# ========================================
REDIS_URL=redis://:your_redis_password@redis:6379
REDIS_TTL=3600

# ========================================
# AI PROVIDER CONFIGURATION
# ========================================

# Options: openai | anthropic | ollama | huggingface | mock
AI_PROVIDER=mock

# OpenAI Configuration (Paid)
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4-turbo-preview

# Anthropic Configuration (Paid)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Ollama Configuration (FREE - Local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Hugging Face Configuration (FREE - Inference API)
HUGGINGFACE_API_KEY=hf-your-huggingface-key-here
HUGGINGFACE_MODEL=microsoft/DialoGPT-medium
HUGGINGFACE_BASE_URL=https://api-inference.huggingface.co/models

# ========================================
# RATE LIMITING
# ========================================
RATE_LIMIT_PER_MINUTE=60
MAX_TOKENS=2000
MAX_HISTORY_MESSAGES=20

# ========================================
# LANGUAGE SUPPORT
# ========================================
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=["en", "mn"]

# ========================================
# MONITORING
# ========================================
PROMETHEUS_ENABLED=true
METRICS_PATH=/metrics
