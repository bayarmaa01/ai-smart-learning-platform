# EduAI Platform - Environment Configuration
# ============================================================

# Database Configuration
DB_PASSWORD=eduai_secure_pass
DB_HOST=localhost
DB_PORT=5432
DB_NAME=eduai_db
DB_USER=postgres

# Redis Configuration
REDIS_PASSWORD=redis_secure_pass
REDIS_URL=redis://:redis_secure_pass@localhost:6379

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_at_least_32_characters_long
JWT_REFRESH_SECRET=your_super_secret_refresh_key_at_least_32_characters_long

# AI Service Configuration
AI_PROVIDER=mock
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
HUGGINGFACE_API_KEY=

# MinIO/S3 Configuration
MINIO_USER=minioadmin
MINIO_PASSWORD=minio_secure_pass
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minio_secure_pass
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=eduai-uploads

# Monitoring Configuration
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# Email Configuration (Optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@eduai.com

# Application URLs
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Development/Production
NODE_ENV=development
DEBUG=false

# Frontend URLs (for Docker build)
VITE_API_URL=http://localhost:5000/api/v1
VITE_AI_URL=http://localhost:8000

# Feature Flags
ENABLE_ANALYTICS=false
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_CLOUD_DEPLOYMENT=false
